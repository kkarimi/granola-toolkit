{
  "name": "@kkarimi/gran-core",
  "version": "0.67.0",
  "description": "Headless runtime and shared library surface for Gran 👵🏻",
  "homepage": "https://kkarimi.github.io/gran/",
  "bugs": {
    "url": "https://github.com/kkarimi/gran/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkarimi/gran.git"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "check": "rm -rf dist && vp check",
    "test": "vp test",
    "typecheck": "vp exec tsc --noEmit"
  },
  "dependencies": {
    "@kkarimi/yazd-core": "github:kkarimi/yazd#bd8ae3f"
  }
}
